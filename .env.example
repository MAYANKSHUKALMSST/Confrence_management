# Server Configuration
PORT=3001
JWT_SECRET=your_jwt_secret_here

# High-Availability (HA) Configuration
# SERVER_ROLE: 'primary' or 'backup'
SERVER_ROLE=primary
PEER_SERVER_URL=http://172.16.100.25
SYNC_SECRET=your_secure_sync_secret_here
SYNC_INTERVAL_MS=300000

# Deployment Credentials (Used by scripts/deploy.js)
# Do not commit your actual password!
SSH_PASSWORD=your_server_password_here

# Email Settings (Optional)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# EMAIL=your-email@gmail.com
# APP_PASSWORD=your-app-password
